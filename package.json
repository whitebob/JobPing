    "test:envelope": "node examples/tests/envelope_mock.mjs",
    "test:jpitem-queue": "node examples/tests/jpitem_queue_mock.mjs",
    "test:transport": "node examples/tests/transport_mock.mjs",
    "test:state-sync": "node examples/tests/state_sync_mock.mjs",
    "test:result-handoff": "node examples/tests/result_handoff_mock.mjs",
    "test:endpoint-proxy": "node examples/tests/endpoint_proxy.mjs",
    "test:wrappers": "node examples/tests/client_server_wrapper_mock.mjs",
    "test:unload": "node examples/tests/jobping_unload.mjs",
    "test:fallback-matrix": "node examples/tests/fallback_matrix.mjs",
    "test:python": ".venv/bin/pytest",
